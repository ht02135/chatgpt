<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="simple.chatgpt.mapper.management.security.RoleGroupManagementMapper">

    <resultMap id="RoleGroupManagementResultMap" type="simple.chatgpt.pojo.management.RoleGroupManagementPojo">
        <id property="id" column="id"/>
        <result property="groupName" column="group_name"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- SELECT -->
    <select id="findAllRoleGroups" resultMap="RoleGroupManagementResultMap">
        SELECT * FROM role_group_management
    </select>

    <select id="findRoleGroupById" resultMap="RoleGroupManagementResultMap">
        SELECT * FROM role_group_management WHERE id = #{id}
    </select>

    <select id="findRoleGroupByName" resultMap="RoleGroupManagementResultMap">
        SELECT * FROM role_group_management WHERE group_name = #{groupName}
    </select>

    <!-- INSERT -->
    <insert id="insertRoleGroup" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO role_group_management (group_name, description)
        VALUES (#{groupName}, #{description})
    </insert>

    <!-- UPDATE -->
    <update id="updateRoleGroup">
        UPDATE role_group_management
        <set>
            <if test="groupName != null">group_name = #{groupName},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- DELETE -->
    <delete id="deleteRoleGroupById">DELETE FROM role_group_management WHERE id = #{id}</delete>
    <delete id="deleteRoleGroupByName">DELETE FROM role_group_management WHERE group_name = #{groupName}</delete>

</mapper>
