<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="simple.chatgpt.mapper.management.security.UserManagementRoleGroupMappingMapper">

    <resultMap id="UserManagementRoleGroupMappingResultMap" type="simple.chatgpt.pojo.management.UserManagementRoleGroupMappingPojo">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="roleGroupId" column="role_group_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- SELECT -->
    <select id="findAllUserRoleGroups" resultMap="UserManagementRoleGroupMappingResultMap">
        SELECT * FROM user_management_role_group_mapping
    </select>

    <select id="findByUserId" resultMap="UserManagementRoleGroupMappingResultMap">
        SELECT * FROM user_management_role_group_mapping WHERE user_id = #{userId}
    </select>

    <select id="findByRoleGroupId" resultMap="UserManagementRoleGroupMappingResultMap">
        SELECT * FROM user_management_role_group_mapping WHERE role_group_id = #{roleGroupId}
    </select>

    <!-- INSERT -->
    <insert id="insertUserRoleGroup" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_management_role_group_mapping (user_id, role_group_id)
        VALUES (#{userId}, #{roleGroupId})
    </insert>

    <!-- DELETE -->
    <delete id="deleteUserRoleGroupById">DELETE FROM user_management_role_group_mapping WHERE id = #{id}</delete>
    <delete id="deleteUserRoleGroupByUserAndGroup">
        DELETE FROM user_management_role_group_mapping
        WHERE user_id = #{userId} AND role_group_id = #{roleGroupId}
    </delete>

</mapper>
