<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="simple.chatgpt.mapper.management.security.RoleGroupRoleMappingMapper">

    <resultMap id="RoleGroupRoleMappingResultMap" type="simple.chatgpt.pojo.management.RoleGroupRoleMappingPojo">
        <id property="id" column="id"/>
        <result property="roleGroupId" column="role_group_id"/>
        <result property="roleId" column="role_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- SELECT -->
    <select id="findAllMappings" resultMap="RoleGroupRoleMappingResultMap">
        SELECT * FROM role_group_role_mapping
    </select>

    <select id="findByRoleGroupId" resultMap="RoleGroupRoleMappingResultMap">
        SELECT * FROM role_group_role_mapping WHERE role_group_id = #{roleGroupId}
    </select>

    <select id="findByRoleId" resultMap="RoleGroupRoleMappingResultMap">
        SELECT * FROM role_group_role_mapping WHERE role_id = #{roleId}
    </select>

    <!-- INSERT -->
    <insert id="insertMapping" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO role_group_role_mapping (role_group_id, role_id)
        VALUES (#{roleGroupId}, #{roleId})
    </insert>

    <!-- DELETE -->
    <delete id="deleteMappingById">DELETE FROM role_group_role_mapping WHERE id = #{id}</delete>
    <delete id="deleteMappingByGroupAndRole">
        DELETE FROM role_group_role_mapping
        WHERE role_group_id = #{roleGroupId} AND role_id = #{roleId}
    </delete>

</mapper>
